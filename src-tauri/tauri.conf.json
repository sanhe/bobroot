{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bobroot",
  "version": "0.1.0",
  "identifier": "app.bobroot.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Bobroot",
        "width": 1220,
        "height": 760,
        "minWidth": 880,
        "minHeight": 540
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**", "$TEMP/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
